# ── GitHub ───────────────────────────────────────────────────
# Token PAT con permessi read:repo
# Senza token, MonadicDashboard usa mock data (funziona comunque)
GITHUB_TOKEN=ghp_...

# ── NuGet ────────────────────────────────────────────────────
# Necessario solo per monadic release
NUGET_API_KEY=...

# ── Cache TTL (secondi) ───────────────────────────────────────
NUGET_CACHE_TTL=300
GITHUB_CACHE_TTL=60

# ── MonadicStudio ─────────────────────────────────────────────
# Path locale esposto al container per aprire progetti .cs
# Windows: C:\Users\adani
# Linux/Mac: /home/danny
WORKSPACE_ROOT=C:\Users\adani
